<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <PackageTargetFrameworks>net8.0;net10.0</PackageTargetFrameworks>
    <DemoAppTargetFrameworks>net8.0;net10.0</DemoAppTargetFrameworks>
    <TestTargetFrameworks>net8.0;net10.0</TestTargetFrameworks>
  </PropertyGroup>

  <PropertyGroup>
    <AvaloniaVersion>12.0.0</AvaloniaVersion>
    <DemoAvaloniaVersion>12.0.0</DemoAvaloniaVersion>
    <EnableAvaloniaEdit>enabled</EnableAvaloniaEdit>
    <AvaloniaEditVersion>12.0.0</AvaloniaEditVersion>
    <AvaloniaSvgVersion>12.0.0-rc1</AvaloniaSvgVersion>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(AVA_VER)' != '' ">
    <TestAvaloniaVersion>$(AVA_VER)</TestAvaloniaVersion>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(AVA_VER)' == '' ">
    <TestAvaloniaVersion>$(AvaloniaVersion)</TestAvaloniaVersion>
  </PropertyGroup>

  <PropertyGroup>
    <PackageVersion>12.0.0-a1</PackageVersion>
  </PropertyGroup>

</Project>


