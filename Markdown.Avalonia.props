<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--<PropertyGroup Condition=" '$(OS)' == 'Windows_NT' ">
    <PackageTargetFrameworks>net461;netstandard2.0;net6</PackageTargetFrameworks>
    <DemoAppTargetFrameworks>net461;netcoreapp3.1;net6;net7</DemoAppTargetFrameworks>
    <TestTargetFrameworks>net6</TestTargetFrameworks>-->
  <PropertyGroup>   
    <PackageTargetFrameworks>net8.0</PackageTargetFrameworks>
    <DemoAppTargetFrameworks>net8.0</DemoAppTargetFrameworks>
    <TestTargetFrameworks>net8.0</TestTargetFrameworks>  
  </PropertyGroup>

  <!--<PropertyGroup Condition=" '$(IS_WHISTYUN_PC)' == 'Y' ">
    <TestTargetFrameworks>netcoreapp3.1;net5;net6;net7</TestTargetFrameworks>
  </PropertyGroup>-->

  <PropertyGroup>
    <AvaloniaVersion>11.3.8</AvaloniaVersion>
    <DemoAvaloniaVersion>11.3.8</DemoAvaloniaVersion>
    <EnableAvaloniaEdit>enabled</EnableAvaloniaEdit>
    <AvaloniaEditVersion>11.3.8</AvaloniaEditVersion>
    <AvaloniaSvgVersion>11.3.0</AvaloniaSvgVersion>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(AVA_VER)' != '' ">
    <TestAvaloniaVersion>$(AVA_VER)</TestAvaloniaVersion>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(AVA_VER)' == '' ">
    <TestAvaloniaVersion>$(AvaloniaVersion)</TestAvaloniaVersion>
  </PropertyGroup>

  <PropertyGroup>
    <PackageVersion>11.3.8</PackageVersion>
  </PropertyGroup>

  <PropertyGroup>
    <UseAvaloniaFork>True</UseAvaloniaFork>
    <AvaloniaBuildFramework>net8.0</AvaloniaBuildFramework>
    <AvaloniaRootDir>..\..\av_main</AvaloniaRootDir>
    <AvaloniaNativeBuildDir>$(AvaloniaRootDir)\packages\Avalonia\bin</AvaloniaNativeBuildDir>
    <AvaloniaMarkupBuildDir>$(AvaloniaRootDir)\src\Markup\Avalonia.Markup.Xaml.Loader\bin</AvaloniaMarkupBuildDir>
    <AvaloniaSkiaBuildDir>$(AvaloniaRootDir)\src\Skia\Avalonia.Skia\bin</AvaloniaSkiaBuildDir>
    <AvaloniaEditIncludeDir>..\..\AvaloniaEdit\src\AvaloniaEdit</AvaloniaEditIncludeDir>
    <AvaloniaSvgIncludeDir>..\..\AvSvg.Skia\src</AvaloniaSvgIncludeDir>
    <IncludeAvaloniaGenerators Condition="'$(UseAvaloniaFork)' == 'True'">true</IncludeAvaloniaGenerators>
  </PropertyGroup>

</Project>


